<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             x:Class="OfficeDeskReservationSystemUI.DatabaseAdminPage"
             BackgroundColor="#F1F5F9"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Padding="20,25" BackgroundColor="White">
            <Button Grid.Column="0" 
                    Text="{x:Static fa:Solid.ArrowLeft}" 
                    FontFamily="FASolid" 
                    BackgroundColor="Transparent" 
                    TextColor="#2B364A" 
                    FontSize="20" 
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1" 
                   Text="Database Admin" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="#0F172A" 
                   VerticalOptions="Center" 
                   Margin="10,0,0,0" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="20">
            <VerticalStackLayout Spacing="20">

                <Label Text="Maintenance Operations" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       TextColor="#64748B" 
                       Margin="0,10,0,0"/>

                <Border BackgroundColor="#FFFFFF" 
                        Stroke="#E11D48" 
                        StrokeThickness="1" 
                        StrokeShape="RoundRectangle 12">
                    <Grid ColumnDefinitions="*, Auto" Padding="20">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Delete Database" 
                                   FontAttributes="Bold" 
                                   FontSize="16" 
                                   TextColor="#E11D48" />
                            <Label Text="Wipe all tables and structures. Data cannot be recovered." 
                                   FontSize="12" 
                                   TextColor="#64748B" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" 
                                Text="{x:Static fa:Solid.Trash}" 
                                FontFamily="FASolid" 
                                BackgroundColor="#FFF1F2" 
                                TextColor="#E11D48" 
                                WidthRequest="44" 
                                HeightRequest="44" 
                                CornerRadius="22" 
                                Clicked="OnDeleteDatabaseClicked" />
                    </Grid>
                </Border>

                <Label Text="More operations coming soon..." 
                       HorizontalOptions="Center" 
                       TextColor="#94A3B8" 
                       Margin="0,20"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>