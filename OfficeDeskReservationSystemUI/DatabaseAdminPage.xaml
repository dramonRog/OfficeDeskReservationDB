<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             x:Class="OfficeDeskReservationSystemUI.DatabaseAdminPage"
             BackgroundColor="#F1F5F9"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <Grid RowDefinitions="Auto, *">
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Padding="20,25" BackgroundColor="White">
                <Button Grid.Column="0" 
                        Text="{x:Static fa:Solid.ArrowLeft}" 
                        FontFamily="FASolid" 
                        BackgroundColor="Transparent" 
                        TextColor="#2B364A" 
                        FontSize="20" 
                        Clicked="OnBackClicked" />
                <Label Grid.Column="1" 
                       Text="Database Admin" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="#0F172A" 
                       VerticalOptions="Center" 
                       Margin="10,0,0,0" />
            </Grid>

            <ScrollView Grid.Row="1" Padding="20">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Maintenance Operations" FontSize="18" FontAttributes="Bold" TextColor="#64748B" Margin="0,10,0,0"/>

                    <Border BackgroundColor="#FFFFFF" Stroke="#4F46E5" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                        <Grid>
                            <Grid ColumnDefinitions="*, Auto" Padding="20">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="Create Empty Database" FontAttributes="Bold" FontSize="16" TextColor="#4F46E5" />
                                    <Label Text="Initialize database file and table structures." FontSize="12" TextColor="#64748B" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22" StrokeThickness="0" BackgroundColor="#EEF2FF" VerticalOptions="Center">
                                    <Label Text="{x:Static fa:Solid.Database}" FontFamily="FASolid" TextColor="#4F46E5" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                            <Button BackgroundColor="Transparent" CornerRadius="12" Clicked="OnCreateDatabaseClicked" />
                        </Grid>
                    </Border>

                    <Border BackgroundColor="#FFFFFF" Stroke="#059669" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                        <VerticalStackLayout Padding="20" Spacing="15">
                            <Grid>
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label Text="Data Generator" FontAttributes="Bold" FontSize="16" TextColor="#059669" />
                                        <Label Text="Populate database with random test records." FontSize="12" TextColor="#64748B" />
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22" StrokeThickness="0" BackgroundColor="#ECFDF5" VerticalOptions="Center">
                                        <Label Text="{x:Static fa:Solid.Gears}" FontFamily="FASolid" TextColor="#059669" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                </Grid>
                                <Button BackgroundColor="Transparent" Clicked="OnGenerateDataClicked" />
                            </Grid>

                            <HorizontalStackLayout Spacing="10">
                                <Label Text="Count:" VerticalOptions="Center" TextColor="#1E293B" FontAttributes="Bold" />
                                <Border BackgroundColor="#F8FAFC" Stroke="#CBD5E1" StrokeThickness="1" StrokeShape="RoundRectangle 8" WidthRequest="100" Padding="10,0">
                                    <Entry x:Name="GenCountEntry" Text="50" Keyboard="Numeric" HorizontalTextAlignment="Center" TextColor="#1E293B" BackgroundColor="Transparent" />
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="Data Transfer (JSON)" FontSize="18" FontAttributes="Bold" TextColor="#64748B" Margin="0,10,0,0"/>

                    <Border BackgroundColor="#FFFFFF" Stroke="#0891B2" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                        <Grid>
                            <Grid ColumnDefinitions="*, Auto" Padding="20">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="Export to JSON" FontAttributes="Bold" FontSize="16" TextColor="#0891B2" />
                                    <Label Text="Saves JSON file to the project root directory." FontSize="12" TextColor="#64748B" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22" StrokeThickness="0" BackgroundColor="#ECFEFF" VerticalOptions="Center">
                                    <Label Text="{x:Static fa:Solid.FloppyDisk}" FontFamily="FASolid" TextColor="#0891B2" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                            <Button BackgroundColor="Transparent" CornerRadius="12" Clicked="OnExportClicked" />
                        </Grid>
                    </Border>

                    <Border BackgroundColor="#FFFFFF" Stroke="#7C3AED" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                        <Grid>
                            <Grid ColumnDefinitions="*, Auto" Padding="20">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="Import from JSON" FontAttributes="Bold" FontSize="16" TextColor="#7C3AED" />
                                    <Label Text="Imports and displays count of new records." FontSize="12" TextColor="#64748B" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22" StrokeThickness="0" BackgroundColor="#F5F3FF" VerticalOptions="Center">
                                    <Label Text="{x:Static fa:Solid.FolderOpen}" FontFamily="FASolid" TextColor="#7C3AED" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                            <Button BackgroundColor="Transparent" CornerRadius="12" Clicked="OnImportClicked" />
                        </Grid>
                    </Border>

                    <Label Text="Database Transformation" FontSize="18" FontAttributes="Bold" TextColor="#64748B" Margin="0,10,0,0"/>

                    <Border BackgroundColor="#FFFFFF" Stroke="#10B981" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                        <Grid>
                            <Grid ColumnDefinitions="*, Auto" Padding="20">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="Transform to NoSQL" FontAttributes="Bold" FontSize="16" TextColor="#10B981" />
                                    <Label Text="Migrate data to MongoDB instance." FontSize="12" TextColor="#64748B" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22" StrokeThickness="0" BackgroundColor="#F0FDF4" VerticalOptions="Center">
                                    <Label Text="{x:Static fa:Solid.Leaf}" FontFamily="FASolid" TextColor="#10B981" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                            <Button BackgroundColor="Transparent" CornerRadius="12" Clicked="OnTransformToNoSqlClicked" />
                        </Grid>
                    </Border>

                    <Label Text="System" FontSize="18" FontAttributes="Bold" TextColor="#64748B" Margin="0,10,0,0"/>

                    <Border BackgroundColor="#FFFFFF" Stroke="#E11D48" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                        <Grid>
                            <Grid ColumnDefinitions="*, Auto" Padding="20">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="Delete Database" FontAttributes="Bold" FontSize="16" TextColor="#E11D48" />
                                    <Label Text="Wipe all tables and structures." FontSize="12" TextColor="#64748B" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22" StrokeThickness="0" BackgroundColor="#FFF1F2" VerticalOptions="Center">
                                    <Label Text="{x:Static fa:Solid.Trash}" FontFamily="FASolid" TextColor="#E11D48" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                            <Button BackgroundColor="Transparent" CornerRadius="12" Clicked="OnDeleteDatabaseClicked" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <Grid x:Name="LoadingOverlay" IsVisible="False" ZIndex="2000" BackgroundColor="#B30F172A">
            <Border BackgroundColor="#FFFFFF" Padding="35" HorizontalOptions="Center" VerticalOptions="Center" StrokeShape="RoundRectangle 16" StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,10" Opacity="0.2" Radius="30" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="20">
                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" Color="#4F46E5" WidthRequest="50" HeightRequest="50" HorizontalOptions="Center" />
                    <Label x:Name="LoadingMessageLabel" Text="Processing..." FontSize="16" FontAttributes="Bold" TextColor="#0F172A" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>