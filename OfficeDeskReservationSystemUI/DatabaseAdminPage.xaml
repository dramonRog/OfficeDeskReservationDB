<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             x:Class="OfficeDeskReservationSystemUI.DatabaseAdminPage"
             BackgroundColor="#F1F5F9"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Padding="20,25" BackgroundColor="White">
            <Button Grid.Column="0" 
                    Text="{x:Static fa:Solid.ArrowLeft}" 
                    FontFamily="FASolid" 
                    BackgroundColor="Transparent" 
                    TextColor="#2B364A" 
                    FontSize="20" 
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1" 
                   Text="Database Admin" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="#0F172A" 
                   VerticalOptions="Center" 
                   Margin="10,0,0,0" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="20">
            <VerticalStackLayout Spacing="20">

                <Label Text="Maintenance Operations" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       TextColor="#64748B" 
                       Margin="0,10,0,0"/>

                <Border BackgroundColor="#FFFFFF" 
                        Stroke="#4F46E5" 
                        StrokeThickness="1" 
                        StrokeShape="RoundRectangle 12">
                    <Grid ColumnDefinitions="*, Auto" Padding="20">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Create Empty Database" 
                                   FontAttributes="Bold" 
                                   FontSize="16" 
                                   TextColor="#4F46E5" />
                            <Label Text="Initialize database file and table structures." 
                                   FontSize="12" 
                                   TextColor="#64748B" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" 
                                Text="{x:Static fa:Solid.Database}" 
                                FontFamily="FASolid" 
                                BackgroundColor="#EEF2FF" 
                                TextColor="#4F46E5" 
                                WidthRequest="44" 
                                HeightRequest="44" 
                                CornerRadius="22" 
                                Clicked="OnCreateDatabaseClicked" />
                    </Grid>
                </Border>

                <Border BackgroundColor="#FFFFFF" 
                        Stroke="#059669" 
                        StrokeThickness="1" 
                        StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout Padding="20" Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                <Label Text="Data Generator" 
                                       FontAttributes="Bold" 
                                       FontSize="16" 
                                       TextColor="#059669" />
                                <Label Text="Populate database with random test records." 
                                       FontSize="12" 
                                       TextColor="#64748B" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" 
                                    Text="{x:Static fa:Solid.Gears}" 
                                    FontFamily="FASolid" 
                                    BackgroundColor="#ECFDF5" 
                                    TextColor="#059669" 
                                    WidthRequest="44" 
                                    HeightRequest="44" 
                                    CornerRadius="22" 
                                    Clicked="OnGenerateDataClicked" />
                        </Grid>

                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Count:" VerticalOptions="Center" TextColor="#1E293B" FontAttributes="Bold" />
                            <Border BackgroundColor="#F8FAFC" Stroke="#CBD5E1" StrokeThickness="1" StrokeShape="RoundRectangle 8" WidthRequest="100" Padding="10,0">
                                <Entry x:Name="GenCountEntry" Text="50" Keyboard="Numeric" HorizontalTextAlignment="Center" TextColor="#1E293B" BackgroundColor="Transparent" />
                            </Border>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FFFFFF" 
                        Stroke="#E11D48" 
                        StrokeThickness="1" 
                        StrokeShape="RoundRectangle 12">
                    <Grid ColumnDefinitions="*, Auto" Padding="20">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Delete Database" 
                                   FontAttributes="Bold" 
                                   FontSize="16" 
                                   TextColor="#E11D48" />
                            <Label Text="Wipe all tables and structures. Data cannot be recovered." 
                                   FontSize="12" 
                                   TextColor="#64748B" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" 
                                Text="{x:Static fa:Solid.Trash}" 
                                FontFamily="FASolid" 
                                BackgroundColor="#FFF1F2" 
                                TextColor="#E11D48" 
                                WidthRequest="44" 
                                HeightRequest="44" 
                                CornerRadius="22" 
                                Clicked="OnDeleteDatabaseClicked" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>